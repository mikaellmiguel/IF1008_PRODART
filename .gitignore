# ─── DEPENDÊNCIAS ────────────────────────────────────────────────────────────
# Nunca versionar node_modules. O npm workspaces instala tudo na raiz.
node_modules/

# ─── BUILDS ──────────────────────────────────────────────────────────────────
# Artefatos de build gerados automaticamente — nunca versionados
dist/
build/
.next/
out/

# ─── VARIÁVEIS DE AMBIENTE ───────────────────────────────────────────────────
# Arquivos .env contêm segredos (chaves de API, connection strings, etc.)
# Apenas .env.example deve ser commitado para documentar as variáveis necessárias
.env
.env.local
.env.production
.env.development

# ─── PRISMA ──────────────────────────────────────────────────────────────────
# O client gerado pelo Prisma é derivado do schema.prisma — não precisa ser versionado
apps/api/node_modules/.prisma/

# ─── TYPESCRIPT ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── EDITORES E IDES ─────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
.github

# ─── CONFIGURAÇÕES DE APLICATIVO ─────────────────────────────────────────────
**/application.properties
**.key
**/app.pub


# ─── LOGS ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ─── TESTES E COBERTURA ──────────────────────────────────────────────────────
coverage/
.nyc_output/
